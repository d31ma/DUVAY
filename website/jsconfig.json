{
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "bun-types",
      "@types/node"
    ]
  },
  "include": [
    "tachyon-env.d.ts",
    "browser/**/*.js",
    "browser/**/*.ts",
    "server/**/*.js",
    "server/**/*.ts"
  ]
}
